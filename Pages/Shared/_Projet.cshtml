@model Projet_api2.Models.Projet

<div class="col">
    <div class="card h-100 shadow-sm border-0 border-start border-4 rounded-3" style="border-color: #1e3a8a !important;">
        <div class="card-body d-flex flex-column p-4">
            
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h5 class="card-title fw-bold text-dark mb-0 text-truncate" style="max-width: 70%;" title="@Model.Nom">
                    @Model.Nom
                </h5>
                
                @if (Model.Status == Projet_api2.Models.ProjectStatus.Active)
                {
                    <span class="badge rounded-pill bg-success bg-opacity-25 text-success px-3 py-2" style="font-size: 0.70rem; letter-spacing: 0.5px;">ACTIF</span>
                }
                else if (Model.Status == Projet_api2.Models.ProjectStatus.Pending)
                {
                    <span class="badge rounded-pill bg-warning bg-opacity-25 text-warning px-3 py-2" style="font-size: 0.70rem; letter-spacing: 0.5px;">EN ATTENTE</span>
                }
                else
                {
                    <span class="badge rounded-pill bg-secondary bg-opacity-25 text-secondary px-3 py-2" style="font-size: 0.70rem; letter-spacing: 0.5px;">@Model.Status</span>
                }
            </div>
            
            <p class="card-text text-secondary small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                @Model.Description
            </p>
            
            <hr class="text-muted opacity-25 my-3">
            
            <div class="d-flex justify-content-between align-items-center mt-auto">
                <span class="text-muted small fw-semibold">
                    👤 @Model.NomCreateur
                </span>
                <a asp-page="/projet/Details" asp-route-id="@Model.Id" class="btn btn-sm rounded-pill px-3 fw-bold" style="border: 1px solid #1e3a8a; color: #1e3a8a; background: transparent;" onmouseover="this.style.backgroundColor='#1e3a8a'; this.style.color='white';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#1e3a8a';">
                    Voir →
                </a>
            </div>
        </div>
    </div>
</div>