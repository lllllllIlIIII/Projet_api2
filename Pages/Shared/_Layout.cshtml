<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] PManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
    <a class="navbar-brand text-white fw-bold" asp-page="/Index">Pmanager</a>
    
    <div class="navbar-nav ms-auto align-items-center">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="nav-link text-white" asp-page="/Index">Projets</a>
            <a class="nav-link text-white" asp-page="/projet/create">Proposer</a>
            
            @if (User.IsInRole("Admin"))
            {
                <a class="nav-link text-warning fw-bold" asp-page="/admin/dashboard">Admin</a>
            }
            
            <span class="navbar-text text-light mx-3">@User.Identity.Name</span>
            
            <form method="post" asp-page="/account/Logout" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm">Déconnexion</button>
            </form>
        }
        else
        {
            <a class="nav-link text-white" asp-page="/Account/Login">Connexion</a>
        }
    </div>
</nav>

<main class="container mt-4">
    @RenderBody()
</main>

<footer class="footer mt-auto py-3 bg-light text-center">
    <div class="container">
        <span class="text-muted">Project manager &copy; @DateTime.Now.Year</span>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>