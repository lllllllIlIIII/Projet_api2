@page
@model Projet_api2.Pages.account.LoginModel
@{
    ViewData["Title"] = "Connexion";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h2 class="fw-bold">Connexion</h2>
                    <p class="text-muted">Accédez à votre espace de projet</p>
                </div>
                
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold">Adresse Email</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" placeholder="nom@entreprise.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label fw-bold">Mot de passe</label>
                        <input asp-for="Input.Password" class="form-control form-control-lg" placeholder="••••••••" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                            Se connecter
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}